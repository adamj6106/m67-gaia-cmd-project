data extraction code 

SELECT TOP 5000
	source_id,
	ra,
	dec,
	parrallax,
	pmra,
	pmdec,
	phot_g_mean_mag,
	bp_rp
FROM gaiar3.gaia_source
WHERE1 = CONTAINS(
	POINT('ICRS', ra, dec),
	CIRCLE('ICRS', 132.825m 11.8, 1.0)
)
AND parallax > 0
AND bp_rp IS NOT NULL
AND phot_g_mean_mag IS NOT NULL
